{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duckcode.dev/schemas/datalex/metric_contract.schema.json",
  "title": "DataLex metric contract",
  "type": "object",
  "required": ["kind", "name", "domain", "status"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "metric_contract" },
    "id": {
      "type": "string",
      "description": "Stable id consumed by DQL, usually <domain>.metric.<metric_name>."
    },
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "display_name": { "type": "string" },
    "domain": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "description": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "reviewed", "certified", "rejected"] },
    "owner": { "type": "string" },
    "formula": { "type": "string" },
    "grain": { "type": "string" },
    "time_dimension": { "type": "string" },
    "dimensions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "enum": ["semantic_metric", "dbt_metric", "dbt_semantic_model", "dql_block", "external"] },
        "ref": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_models": { "type": "array", "items": { "type": "string" } },
        "columns": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "array", "items": { "type": "string" } },
        "semantic_metrics": { "type": "array", "items": { "type": "string" } },
        "inferred_grain": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "meta": { "type": "object", "additionalProperties": true }
  }
}
