{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duckcode.dev/schemas/datalex/project.schema.json",
  "title": "DataLex project manifest",
  "type": "object",
  "required": ["kind", "name", "version"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "project" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": ["string", "integer"] },
    "description": { "type": "string" },
    "owner": { "type": "string" },
    "dialects": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
      "description": "Enabled dialect plugins. Must correspond to modules under datalex_core/dialects/."
    },
    "default_dialect": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "glossary": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for glossary files, e.g. 'glossary/**/*.yaml'."
    },
    "models": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for entity/source/model files, e.g. 'models/**/*.yaml'."
    },
    "sources": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for kind:source files, e.g. 'sources/**/*.yaml'. Optional."
    },
    "domains": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for kind:domain files, default 'domains/**/*.yaml'."
    },
    "snippets": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for snippet files, default '.datalex/snippets/**/*.yaml'."
    },
    "policies": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for policy files."
    },
    "relationships": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for kind:relationship files, default 'relationships/**/*.yaml'."
    },
    "data_types": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for kind:data_type files, default 'data_types/**/*.yaml'."
    },
    "semantic_models": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for kind:semantic_model files, default 'semantic/**/*.yaml'."
    },
    "metric_contracts": {
      "$ref": "#/$defs/globOrGlobs",
      "description": "Glob(s) for kind:metric_contract files, default '*/semantic/**/*.yaml'."
    },
    "contracts": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Glob(s) for first-class kind:contract files. Defaults include contracts/** and DataLex/*/Contracts/**."
    },
    "proposals": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Glob(s) for first-class kind:proposal files. Draft AI outputs stay here until review/certification."
    },
    "diagrams": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Glob for kind:diagram files. Defaults include domain-first DataLex/*/(conceptual|logical|physical) paths and legacy datalex/diagrams paths."
    },
    "imports": {
      "type": "array",
      "description": "Cross-repo package imports. Resolver fetches packages into ~/.datalex/packages/ and pins them in .datalex/lock.yaml.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package"],
        "properties": {
          "package": {
            "type": "string",
            "description": "Package identifier. Forms: 'org/name', 'org/name@version', or any Git-URL-like string when paired with git:."
          },
          "alias": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "path": {
            "type": "string",
            "description": "Local directory (relative to project root or absolute). Mutually exclusive with git:."
          },
          "git": {
            "type": "string",
            "description": "Git URL (https or ssh) to clone for resolution."
          },
          "ref": {
            "type": "string",
            "description": "Git ref — tag, branch, or commit SHA."
          },
          "version": {
            "type": "string",
            "description": "Version override (falls back to parsing 'org/name@version' from package:)."
          },
          "entities": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "description": "Optional allowlist of entity names to import (default: all)."
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "globOrGlobs": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    }
  }
}
