{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duckcode.dev/schemas/datalex/contract.schema.json",
  "title": "DataLex business contract",
  "type": "object",
  "required": ["kind", "name", "domain", "entity", "version", "status"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "contract" },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]*\\.[A-Z][A-Za-z0-9]*\\.[a-z][a-z0-9_]*$",
      "description": "Stable id consumed by DQL, usually <domain>.<Entity>.<contract_name>."
    },
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "display_name": { "type": "string" },
    "domain": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "entity": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "description": { "type": "string" },
    "business_definition": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "type": "string", "enum": ["draft", "reviewed", "certified", "rejected"] },
    "owner": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "grain": { "type": "string" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["dbt_model", "dbt_source", "view", "table", "external"] },
        "ref": { "type": "string" }
      }
    },
    "dbt_contract": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model": { "type": "string" },
        "unique_id": { "type": "string" },
        "enforced": { "type": "boolean" },
        "source_of_truth": { "type": "boolean" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/param" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/param" }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric_contract" }
    },
    "dimensions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_tests": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence": { "$ref": "#/$defs/evidence" },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cadence": { "type": "string" },
        "reviewers": { "type": "array", "items": { "type": "string" } },
        "last_reviewed_at": { "type": "string" }
      }
    },
    "meta": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "param": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metric_contract": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "formula": { "type": "string" },
        "grain": { "type": "string" },
        "time_dimension": { "type": "string" },
        "dimensions": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "owner": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "reviewed", "certified", "rejected"] }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_models": { "type": "array", "items": { "type": "string" } },
        "columns": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "array", "items": { "type": "string" } },
        "semantic_metrics": { "type": "array", "items": { "type": "string" } },
        "inferred_grain": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
